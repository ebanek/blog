---
---
<div class="pdf-char-count">
  <label for="char-file-input" class="char-upload-btn">Choose a PDF to count characters</label>
  <input type="file" id="char-file-input" accept=".pdf">
  <p id="char-result"></p>
</div>

<style>
  .pdf-char-count {
    margin: 1.5rem 0;
  }
  .char-upload-btn {
    display: inline-block;
    background: #333;
    color: #fff;
    border: none;
    padding: 0.6rem 1.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
  }
  .char-upload-btn:hover {
    background: #555;
  }
  #char-file-input {
    display: none;
  }
  #char-result {
    margin-top: 1rem;
    color: #666;
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/pdfjs-dist@4.9.155/build/pdf.min.mjs" type="module"></script>
<script is:inline type="module">
  const pdfjsLib = globalThis.pdfjsLib;
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.9.155/build/pdf.worker.min.mjs';

  const fileInput = document.getElementById('char-file-input');
  const result = document.getElementById('char-result');

  fileInput.addEventListener('change', async () => {
    const file = fileInput.files[0];
    if (!file) return;

    result.textContent = 'Counting...';

    try {
      const bytes = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
      let totalChars = 0;

      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        const pageText = content.items.map(item => item.str).join('');
        totalChars += pageText.length;
      }

      result.textContent = `${file.name}: ${totalChars.toLocaleString()} characters (${pdf.numPages} pages)`;
    } catch (err) {
      result.textContent = `Error: ${err.message}`;
    }

    fileInput.value = '';
  });
</script>
